# Postgres connection string (Neon)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Prognosis API
PROGNOSIS_BASE="https://prognosis-api.leadwayhealth.com"

# Dedicated Prognosis service account for this app. Used two ways:
# 1. HTTP Basic auth on staff sign-in (ExternalPortalLogin) — identifies this
#    app/portal to Prognosis; the actual staff member's own credentials go
#    in the request body, not here.
# 2. Username/password login (ApiUsers/Login) to get a Bearer token for
#    sending member notification emails/SMS.
PROGNOSIS_SERVICE_USERNAME=""
PROGNOSIS_SERVICE_PASSWORD=""

# Comma-separated Prognosis usernames that are auto-granted Admin role on first login
ADMIN_USERNAMES="f-komoni-mbaekwe"
