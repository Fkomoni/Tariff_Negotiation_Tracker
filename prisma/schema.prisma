generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONTACT_CENTER
  PROVIDER_TEAM
  PENDING
}

enum ServiceType {
  CONSULTATION
  MEDICATIONS
  INVESTIGATIONS
  ADMISSION_RELATED_SERVICES
  PROCEDURES_AND_SERVICES
  SURGERIES
}

enum Urgency {
  ROUTINE
  URGENT
  EMERGENCY
}

enum CaseStatus {
  NEW_REQUEST
  UNDER_REVIEW
  NEGOTIATING
  AWAITING_PROVIDER_FEEDBACK
  AWAITING_INTERNAL_APPROVAL
  COMPLETED
  DECLINED
  ESCALATED
}

enum RequestType {
  EXISTING_TARIFF_UPDATE
  NEW_SERVICE
}

/// Top-level split at logging time: a real tariff negotiation that pushes
/// to Prognosis (everything the app did before this), vs. a general
/// Provider Management issue that just needs to land in the same queue
/// with no API call involved.
enum CaseType {
  TARIFF_UPDATE
  PROVIDER_MANAGEMENT
}

/// Categories for CaseType.PROVIDER_MANAGEMENT requests, grouped in the UI
/// (see PM_CATEGORY_GROUPS in src/lib/domain.ts) so reports can break down
/// volume by category and by group.
enum ProviderManagementCategory {
  PORTAL_LOGIN_ISSUE
  PROVIDER_SIGN_UP_REQUEST
  NEW_FACILITY_SIGN_ON
  CONTACT_INFO_UPDATE
  BANK_INFO_UPDATE
  FACILITY_TIER_CHANGE
  FULL_TARIFF_REVIEW_REQUEST
  PROVIDER_SUSPENDED_US
  PROVIDER_DEACTIVATION_REQUEST
  COMPLIANCE_DOCUMENT_UPDATE
  REPORT_ABUSE_FRAUD
  REPORT_POOR_ENROLLEE_EXPERIENCE
  OTHER
}

enum UpdateType {
  STATUS_CHANGE
  NOTE
  NOTIFICATION
  OWNER_CHANGE
}

enum NotificationUrgencyTemplate {
  ROUTINE
  URGENT
}

enum NotificationStatus {
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum AuditAction {
  LOGIN
  ROLE_CHANGE
  MFA_ENABLED
  MFA_DISABLED
}

enum MfaCodePurpose {
  LOGIN
  ENABLE
}

model User {
  id                String   @id @default(cuid())
  prognosisUsername String   @unique
  displayName        String?
  email               String?
  role                Role     @default(PENDING)
  lastLoginAt         DateTime?
  /// Per-user opt-in for email-OTP MFA at login. Off by default — set via
  /// the Account Security page (enableMfa/confirmEnableMfa in mfa-actions.ts).
  mfaEnabled          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  loggedCases    NegotiationCase[] @relation("LoggedBy")
  ownedCases     NegotiationCase[] @relation("OwnedBy")
  caseUpdates    CaseUpdate[]
  notifications  MemberNotification[]
  auditLogs      AuditLog[]
  mfaCodes       MfaCode[]
  trustedDevices TrustedDevice[]
}

/// Single-use, hashed email OTPs — used both for the login MFA challenge and
/// for confirming a user actually controls their on-file email before
/// enabling MFA on their account.
model MfaCode {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  purpose    MfaCodePurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([userId, purpose])
}

/// A browser that completed an MFA challenge and was marked "trusted" by the
/// user — the token (hashed) lives in an httpOnly cookie and lets that
/// browser skip the OTP challenge until expiresAt (90 days out).
model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

/// System-wide audit trail for events that aren't tied to a single
/// NegotiationCase (logins, role changes). Case-level activity already has
/// its own detailed trail via CaseUpdate; the Audit Log page merges both.
model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  actor       User?       @relation(fields: [actorUserId], references: [id])
  action      AuditAction
  summary     String
  createdAt   DateTime    @default(now())

  @@index([action])
  @@index([createdAt])
}

model NegotiationCase {
  id                     String      @id @default(cuid())
  caseNumber             String      @unique

  providerName           String
  providerCode           String?
  providerId             Int?
  providerEmail          String?
  providerPhone          String?
  enrolleeName           String
  enrolleeId             String?
  enrolleeEmail          String?
  enrolleePhone          String?
  enrolleeCompany        String?
  enrolleeScheme         String?
  enrolleeAge            Int?

  /// Top-level split from the logging form — TARIFF_UPDATE is everything
  /// that existed before this field (pushes to Prognosis); PROVIDER_MANAGEMENT
  /// is a general provider-management issue with no API call, sharing the
  /// same queue/workflow/reporting.
  caseType               CaseType    @default(TARIFF_UPDATE)

  serviceType            ServiceType?
  requestType            RequestType @default(EXISTING_TARIFF_UPDATE)
  requestedItem          String
  serviceCode            String?
  providerTariffCode     String?
  currentTariff          Decimal     @db.Decimal(14, 2) @default(0)
  providerRequestedAmount Decimal    @db.Decimal(14, 2) @default(0)
  reason                 String
  urgency                Urgency     @default(ROUTINE)
  notes                  String?

  /// Multi-select categories for a PROVIDER_MANAGEMENT case — empty for
  /// TARIFF_UPDATE cases.
  pmCategories           ProviderManagementCategory[] @default([])
  /// Letterhead/document attachment for categories like Bank Info Update —
  /// stored directly in Postgres (low volume, small files, no object
  /// storage set up for this app).
  pmAttachmentName       String?
  pmAttachmentMimeType   String?
  pmAttachmentData       Bytes?

  status                 CaseStatus  @default(NEW_REQUEST)
  finalAgreedAmount      Decimal?    @db.Decimal(14, 2)
  approvalReason         String?
  tariffPushedAt         DateTime?
  /// When the new/updated price should take effect on Prognosis's side —
  /// set by Provider Team when marking a case Completed, sent as
  /// EffectiveDate on the AddTarrifReviews push.
  tariffEffectiveDate    DateTime?

  /// Groups multiple service negotiations logged for the same provider
  /// visit ("quick repeat") without merging their independent statuses/timers.
  sessionGroupId         String?

  loggedByUserId         String
  loggedBy               User        @relation("LoggedBy", fields: [loggedByUserId], references: [id])
  loggedAt               DateTime    @default(now())

  ownerUserId            String?
  owner                  User?       @relation("OwnedBy", fields: [ownerUserId], references: [id])

  firstActionAt          DateTime?
  completedAt            DateTime?

  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  updates       CaseUpdate[]
  notifications MemberNotification[]

  @@index([status])
  @@index([urgency])
  @@index([providerName])
  @@index([loggedAt])
  @@index([sessionGroupId])
}

model CaseUpdate {
  id             String     @id @default(cuid())
  caseId         String
  case           NegotiationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  userId         String
  user           User       @relation(fields: [userId], references: [id])

  type           UpdateType
  previousStatus CaseStatus?
  newStatus      CaseStatus?
  note           String?

  createdAt      DateTime   @default(now())

  @@index([caseId])
}

model MemberNotification {
  id            String   @id @default(cuid())
  caseId        String
  case          NegotiationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  sentByUserId  String
  sentBy        User     @relation(fields: [sentByUserId], references: [id])

  template      NotificationUrgencyTemplate
  channel       NotificationChannel
  message       String
  recipientEmail String?
  recipientPhone String?
  status        NotificationStatus
  errorMessage  String?

  createdAt     DateTime @default(now())

  @@index([caseId])
}

/// One row per Prognosis service/treatment master catalog entry — persisted
/// so the full list survives app restarts/redeploys and doesn't need
/// refetching from Prognosis every time the in-memory cache is cold. Synced
/// wholesale (replace-all) once a day via LookupSync, or on demand via the
/// Configuration "Sync Now" button.
model ProcedureCatalogEntry {
  procedureId String  @id
  name        String
  tariffId    Int?
}

/// Tracks when each wholesale lookup-list sync last ran, so the app knows
/// whether the persisted copy is still good for today or needs refreshing.
model LookupSync {
  key          String   @id
  lastSyncedAt DateTime
  recordCount  Int
}
